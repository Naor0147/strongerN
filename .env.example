# StrongerN — Environment Variables Template
# ✅ SAFE TO COMMIT — contains no real secrets.
# Developers: copy this file to .env and fill in real values.
#
#   cp .env.example .env
#

# ─────────────────────────────────────────────
# Google OAuth — Android Client ID
# Get this from: https://console.cloud.google.com
# APIs & Services → Credentials → OAuth 2.0 Client IDs
# Create an "Android" type client with:
#   Package name:  com.naor.strongern
#   SHA-1 (debug): run `keytool -keystore ~/.android/debug.keystore -list -v`
# ─────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_OAUTH_CLIENT_ID_HERE.apps.googleusercontent.com

# ─────────────────────────────────────────────
# Google OAuth — Web Client ID (optional)
# Only needed if you also want web/Expo Go OAuth flows.
# Create a "Web application" type client in Google Cloud Console.
# Leave blank to fall back to the Android client ID.
# ─────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
