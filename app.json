{
  "expo": {
    "name": "StrongerN",
    "slug": "strongerN",
    "scheme": [
      "strongern",
      "com.googleusercontent.apps.81738149264-q7gqeu0nvksebi02nrce68blhfqlhe1q"
    ],
    "version": "1.0.0",
    "jsEngine": "hermes",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0F14",
    "splash": {
      "backgroundColor": "#0D0F14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.naor.strongern"
    },
    "android": {
      "package": "com.naor.strongern",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0D0F14",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "strongern"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ]
    ]
  }
}